@page "/iframe-nomeroff"

@inject SettingsService SettingsSvc

<PageTitle>Nomeroff</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h4">Nomeroff - модуль распознавания номеров</MudText>
    <MudText Typo="Typo.body2">
        Веб-интерфейс Python-сервиса номеров (если он его предоставляет) и/или Swagger.
    </MudText>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Адрес Python Nomeroff API</MudText>
            <MudChip Color="Color.Primary" T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Dns">
                @_nomeroffApiBaseUrl
            </MudChip>
            <MudAlert Severity="Severity.Info" Dense="true">
                Сервис Python должен быть запущен по этому адресу (по умолчанию <b>http://127.0.0.1:8000</b>).
            </MudAlert>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-0" Outlined="true" Style="overflow:hidden;">
        <iframe id="nomeroffFrame"
                title="Nomeroff API"
                src="@_nomeroffApiBaseUrl"
                style="border:none; width:100%; height:65vh; color:lightgrey;"
                loading="lazy">
            <p>Ваш браузер не поддерживает iframe</p>
        </iframe>
    </MudPaper>
</MudStack>

@code {
    private string _nomeroffApiBaseUrl = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var url = await SettingsSvc.GetApiBaseUrlAsync();

        try
        {
            var uri = new Uri(url);
            _nomeroffApiBaseUrl = $"{uri.Scheme}://{uri.DnsSafeHost}:{uri.Port}";
        }
        catch
        {
            _nomeroffApiBaseUrl = url;
        }
        await InvokeAsync(StateHasChanged);
    }
}
