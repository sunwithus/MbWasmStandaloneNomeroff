@page "/iframe-db"

@inject SettingsService SettingsSvc

<PageTitle>RecordsApi</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h4">Nomeroff.Interbase.Api - модуль работы с БД</MudText>
    <MudText Typo="Typo.body2">
        Просмотр SQLite-БД (файлы по датам) и Swagger интерфейса API записей.
    </MudText>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Адрес Interbase API</MudText>
            <MudChip Color="Color.Primary" T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Storage">
                @(_recordsApiBaseUrl)
            </MudChip>
            <MudAlert Severity="Severity.Info" Dense="true">
                Убедитесь, что сервис <b>Nomeroff.Interbase.Api</b> запущен на этом адресе.
            </MudAlert>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-0" Outlined="true" Style="overflow:hidden; color:lightgrey; background-color:aqua;">
        <iframe id="recordsFrame"
                title="RecordsApi"
                src="@_recordsApiBaseUrl"
                style="border:none; width:100%; height:65vh;"
                loading="lazy">
            <p>Ваш браузер не поддерживает iframe</p>
        </iframe>
    </MudPaper>
</MudStack>

@code {
    private string _recordsApiBaseUrl = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var url = await SettingsSvc.GetRecordsApiBaseUrlAsync();

        try
        {
            var uri = new Uri(url);
            _recordsApiBaseUrl = $"{uri.Scheme}://{uri.DnsSafeHost}:{uri.Port}";
        }
        catch
        {
            _recordsApiBaseUrl = url;
        }
        await InvokeAsync(StateHasChanged);
    }
}
