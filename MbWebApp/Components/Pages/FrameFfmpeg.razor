@page "/iframe-video"

@inject SettingsService SettingsSvc

<PageTitle>Video API</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h4">Nomeroff.Video.Api</MudText>
    <MudText Typo="Typo.body2">
        Swagger и веб-интерфейс Video API.
    </MudText>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Адрес Video API</MudText>
            <MudChip Color="Color.Primary" T="string" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.LocationOn">
                @(_videoApiBaseUrl)
            </MudChip>
            <MudAlert Severity="Severity.Info" Dense="true">
                Убедитесь, что сервис <b>Nomeroff.Video.Api</b> запущен на этом адресе.
            </MudAlert>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-0" Outlined="true" Style="overflow:hidden;">
        <iframe id="videoFrame"
                title="Video API"
                src="@_videoApiBaseUrl"
                style="border:none; width:100%; height:65vh;"
                loading="lazy">
            <p>Ваш браузер не поддерживает iframe</p>
        </iframe>
    </MudPaper>
</MudStack>

@code {
    private string _videoApiBaseUrl = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var url = await SettingsSvc.GetVideoApiBaseUrlAsync();
        try
        {
            var uri = new Uri(url);
            _videoApiBaseUrl = $"{uri.Scheme}://{uri.DnsSafeHost}:{uri.Port}";
        }
        catch
        {
            _videoApiBaseUrl = url;
        }
        await InvokeAsync(StateHasChanged);
    }
}
