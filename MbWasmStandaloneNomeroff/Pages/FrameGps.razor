@* FrameGps.razor — iframe для Nomeroff.Gps.Api *@

@page "/iframe-gps"

@inject SettingsService SettingsSvc

<PageTitle>GPS API</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h4">Nomeroff.Gps.Api</MudText>
    <MudText Typo="Typo.body2">
        Swagger и веб-интерфейс GPS API (NMEA через COM-порт).
    </MudText>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Адрес GPS API</MudText>
            <MudChip Color="Color.Primary" T="String" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.LocationOn">
                @(_gpsApiBaseUrl)
            </MudChip>
            <MudAlert Severity="Severity.Info" Dense="true">
                Убедитесь, что сервис <b>Nomeroff.Gps.Api</b> запущен на этом адресе.
            </MudAlert>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-0" Outlined="true" Style="overflow:hidden;">
        <iframe id="gpsFrame"
                title="GPS API"
                src="@_gpsApiBaseUrl"
                style="border:none; width:100%; height:65vh;"
                loading="lazy">
            <p>Твой браузер устарел для отображения элемента iframe</p>
        </iframe>
    </MudPaper>
</MudStack>

@code {
    private string _gpsApiBaseUrl = "";

    protected override async Task OnInitializedAsync()
    {
        var url = await SettingsSvc.GetGpsApiBaseUrlAsync();
        await base.OnInitializedAsync();
        try
        {
            var uri = new Uri(url);
            _gpsApiBaseUrl = $"{uri.Scheme}://{uri.DnsSafeHost}:{uri.Port}";
        }
        catch
        {
            _gpsApiBaseUrl = url;
        }
    }
}
